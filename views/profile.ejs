<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Perfil - Positivamente</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/index.css">
</head>
<body>
  <div id="appContainer" class="app-container">
    <header class="header">
      <div class="logo">
        <i class="fas fa-leaf"></i>
        Positivamente
      </div>
      <div class="user-menu">
        <a href="/" class="back-link"><i class="fas fa-arrow-left"></i> Voltar</a>
        <div class="user-avatar"><%= currentUser.name.split(' ').map(n => n[0]).join('').toUpperCase() %></div>
        <a href="/logout" class="logout-link" title="Sair"><i class="fas fa-sign-out-alt"></i></a>
      </div>
    </header>

    <main class="main-layout">
      <div class="main-content" style="margin: 0 auto;">
        <section class="content-section active">
          <div class="section-header">
            <i class="fas fa-user"></i>
            <div>
              <h2 class="section-title">Meu Perfil</h2>
              <p class="section-subtitle">Gerencie suas informações pessoais e acompanhe seu progresso</p>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-section">
              <h3>Informações Pessoais</h3>
              <form action="/profile" method="POST">
                <div class="form-group">
                  <label for="profileFullName">Nome Completo</label>
                  <input type="text" id="profileFullName" name="name" value="<%= user.name %>">
                </div>
                <div class="form-group">
                  <label for="profileEmail">Email</label>
                  <input type="email" id="profileEmail" value="<%= user.email %>" disabled>
                </div>
                <div class="form-group">
                  <label for="profilePhone">Telefone</label>
                  <input type="tel" id="profilePhone" name="phone" value="<%= user.phone || '' %>">
                </div>
                <div class="form-group">
                  <label for="profileBirthdate">Data de Nascimento</label>
                  <input type="date" id="profileBirthdate" name="birthdate" value="<%= user.birthdate ? user.birthdate.toISOString().split('T')[0] : '' %>">
                </div>
                <div class="form-group">
                  <label for="profileCity">Cidade</label>
                  <input type="text" id="profileCity" name="city" value="<%= user.city || '' %>">
                </div>
                <button type="submit" class="btn-save">Salvar Perfil</button>
              </form>
            </div>

            <div class="form-section">
              <h3>Sistema de Indicações</h3>
              <div class="form-group">
                <label for="myReferralCode">Meu Código de Indicação</label>
                <input type="text" id="myReferralCode" value="<%= user.referral_code %>" readonly>
              </div>
              <div class="form-group">
                <label for="referralBalance">Saldo de Indicações</label>
                <input type="text" id="referralBalance" value="R$ <%= Number(user.referral_earnings || 0).toFixed(2) %>" readonly>
              </div>
              <div class="form-group">
                <label for="totalReferrals">Total de Indicações</label>
                <input type="number" id="totalReferrals" value="<%= user.total_referrals || 0 %>" readonly>
              </div>
            </div>

            <div class="form-section">
              <h3>Estatísticas Pessoais</h3>
              <div class="form-group">
                <label for="personalDaysFree">Dias Sem Fumar</label>
                <input type="number" id="personalDaysFree" value="<%= user.days_free || 0 %>" readonly>
              </div>
              <div class="form-group">
                <label for="personalMoneySaved">Dinheiro Economizado</label>
                <input type="text" id="personalMoneySaved" value="R$ <%= Number(user.money_saved || 0).toFixed(2) %>" readonly>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  </div>
</body>
</html>
